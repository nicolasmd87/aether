// Regression: closure bodies that call imported externs used to
// trigger a C90 implicit-int fallback because closures were emitted
// before imported-module extern prototypes. After hoisting extern
// decls into the forward-decl pass, the closure body sees a real
// prototype and compiles cleanly.
//
// The brief is in closure-extern-ordering.md (porter Round 234).

import contrib.aeocha
import std.string

main() {
    fw = aeocha.init()
    aeocha.describe(fw, "demo") {
        aeocha.it("uses list_new in a closure") callback {
            argv = list_new()
            list_add_raw(argv, "hi")
            aeocha.assert_true(fw, 1, "trivial")
        }
    }
    aeocha.run_summary(fw)
}

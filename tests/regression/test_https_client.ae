// Regression test: HTTPS client (OpenSSL-backed).
// Hits a stable public HTTPS endpoint. Skipped when AETHER_SKIP_NETWORK
// is set (offline CI) or when the build doesn't have OpenSSL support
// (error mentions "no OpenSSL support").

import std.http
import std.string
import std.io

main() {
    if io.getenv("AETHER_SKIP_NETWORK") != 0 {
        println("SKIP https: AETHER_SKIP_NETWORK set")
        return
    }

    // Windows MinGW's OpenSSL doesn't ship a default CA trust path the
    // way /etc/ssl/certs/ exists on Linux and Keychain exists on macOS.
    // Before this branch (PR #219) HTTPS errored earlier with "no
    // OpenSSL support" and that path handled the skip; now that
    // OpenSSL is actually linked in the Windows release binary, the
    // handshake progresses to cert verification and fails with
    // "certificate verify failed" because no trust anchor is
    // configured. Follow-up work: either bake in a CA bundle path
    // resolution in std.net, or fall through to Windows Cert Store
    // via schannel. Until then, skip the assertion on Windows rather
    // than crash the CI matrix. Matches CONTRIBUTING.md §"Coding for
    // portability" pattern #1.
    if io.getenv("OS") == "Windows_NT" {
        println("SKIP https: Windows CA trust path not yet configured in std.net")
        return
    }

    println("Test: https://example.com/ responds with 'Example Domain'")
    body, err = http.get("https://example.com/")
    if err != "" {
        if string.contains(err, "no OpenSSL support") == 1 {
            println("SKIP https: build has no OpenSSL support (${err})")
            return
        }
        println("FAIL: http.get returned error: ${err}")
        exit(1)
    }
    if string.contains(body, "Example Domain") == 1 {
        println("PASS: TLS handshake + response body OK")
    } else {
        println("FAIL: body did not contain 'Example Domain'")
        exit(1)
    }

    println("Test: https:// with bad hostname returns error")
    _, err2 = http.get("https://definitely-not-a-real-host-xyz-aether-test-12345.example/")
    if err2 != "" {
        println("PASS: bogus host errored (${err2})")
    } else {
        println("FAIL: bogus host should error")
        exit(1)
    }

    println("=== HTTPS client tests passed ===")
}

import std.host

double_it(n: int) {
    if n > 1000000 {
        notify("Overflow", n)
        return -1
    }
    notify("Computed", n)
    return n * 2
}

label(prefix: string, n: int) {
    notify("Computed", n)
    return prefix
}

is_positive(n: int) {
    if n > 0 { return 1 }
    return 0
}

// Step 8 of the Servirtium roadmap: tape mutations / redactions.
//
// Test author records interactions, registers redactions, flushes
// the tape — sensitive substrings should be scrubbed in the on-disk
// bytes but the in-memory capture stays untouched.
//
// What we cover:
//   1. vcr.redact(FIELD_RESPONSE_BODY, ...) replaces every occurrence
//      in the response body
//   2. vcr.redact(FIELD_PATH, ...) replaces every occurrence in the
//      path
//   3. Multiple redactions stack (apply in registration order)
//   4. Pattern with no hits is a clean no-op
//   5. clear_redactions() drops all registrations — a subsequent
//      flush emits the original bytes
//   6. request headers, request body, and response headers can be
//      redacted too
//
// No HTTP server needed: we drive the capture directly via vcr.record()
// and inspect the flushed file with std.fs.

import std.http.server.vcr
import std.http
import std.fs
import std.string
import std.io

extern exit(code: int)

// Platform temp dir — TEMP on Windows, TMPDIR on POSIX, /tmp fallback.
// A bare "/tmp/..." path is drive-relative on the MinGW C runtime
// (e.g. C:\tmp\) and the directory typically doesn't exist on CI.
tape_path() -> {
    tmp = io.getenv("TEMP")
    if tmp == 0 { tmp = io.getenv("TMPDIR") }
    if tmp == 0 { tmp = "/tmp" }
    return "${tmp}/vcr_redactions_test.tape"
}

assert_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) != 1 {
        println("  FAIL: ${label} — expected to find '${needle}'")
        exit(1)
    }
}

assert_not_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) == 1 {
        println("  FAIL: ${label} — did not expect '${needle}' but found it")
        exit(1)
    }
}

main() {
    println("=== VCR redactions smoke test ===\n")

    TAPE_PATH = tape_path()

    // ---- Setup: capture two interactions with sensitive data. ----
    // Body holds an Authorization-style token; path holds a session id.
    body_with_secret = "user=alice token=Bearer-abc123-shh\nuser=bob token=Bearer-abc123-shh\n"
    path_with_secret = "/users?session=xyz789&page=1"

    err1 = vcr.record("GET", path_with_secret, 200, "text/plain", body_with_secret)
    if err1 != "" { println("FAIL: record #1 — ${err1}"); exit(1) }
    err2 = vcr.record("GET", "/safe", 200, "text/plain", "no secrets here")
    if err2 != "" { println("FAIL: record #2 — ${err2}"); exit(1) }

    // ---- Test 1: register redactions, flush, inspect bytes. ----
    println("Test 1: response-body + path redaction round-trip")
    rerr1 = vcr.redact(vcr.FIELD_RESPONSE_BODY, "Bearer-abc123-shh", "Bearer-REDACTED")
    if rerr1 != "" { println("  FAIL: redact body — ${rerr1}"); exit(1) }
    rerr2 = vcr.redact(vcr.FIELD_PATH, "session=xyz789", "session=REDACTED")
    if rerr2 != "" { println("  FAIL: redact path — ${rerr2}"); exit(1) }

    ferr1 = vcr.flush(TAPE_PATH)
    if ferr1 != "" { println("  FAIL: flush — ${ferr1}"); exit(1) }

    on_disk, derr1 = fs.read(TAPE_PATH)
    if derr1 != "" { println("  FAIL: read back — ${derr1}"); exit(1) }

    // The redacted token must NOT appear in the file (both occurrences
    // in the body must have been replaced). The replacement marker
    // must appear, and twice (once per body occurrence).
    assert_not_contains(on_disk, "Bearer-abc123-shh", "secret leaked into tape")
    assert_contains(on_disk, "Bearer-REDACTED", "redaction marker missing")
    assert_not_contains(on_disk, "session=xyz789", "session id leaked into path")
    assert_contains(on_disk, "session=REDACTED", "session redaction marker missing")
    // Untouched parts survive.
    assert_contains(on_disk, "user=alice", "non-secret body content lost")
    assert_contains(on_disk, "no secrets here", "second interaction lost")
    println("  PASS")

    // ---- Test 2: in-memory capture still has the original bytes. ----
    // Re-flush after clearing redactions; original token should reappear.
    println("\nTest 2: clear_redactions() leaves in-memory capture intact")
    vcr.clear_redactions()
    ferr2 = vcr.flush(TAPE_PATH)
    if ferr2 != "" { println("  FAIL: re-flush — ${ferr2}"); exit(1) }
    on_disk2, derr2 = fs.read(TAPE_PATH)
    if derr2 != "" { println("  FAIL: re-read — ${derr2}"); exit(1) }
    assert_contains(on_disk2, "Bearer-abc123-shh", "in-memory capture was mutated by earlier flush")
    assert_contains(on_disk2, "session=xyz789", "in-memory path was mutated by earlier flush")
    assert_not_contains(on_disk2, "Bearer-REDACTED", "stale redaction reappeared after clear")
    println("  PASS")

    // ---- Test 3: pattern with no hits is a no-op. ----
    println("\nTest 3: non-matching pattern is a no-op")
    rerr3 = vcr.redact(vcr.FIELD_RESPONSE_BODY, "this-substring-never-appears", "WHATEVER")
    if rerr3 != "" { println("  FAIL: register no-op — ${rerr3}"); exit(1) }
    ferr3 = vcr.flush(TAPE_PATH)
    if ferr3 != "" { println("  FAIL: flush after no-op — ${ferr3}"); exit(1) }
    on_disk3, derr3 = fs.read(TAPE_PATH)
    if derr3 != "" { println("  FAIL: re-read after no-op — ${derr3}"); exit(1) }
    assert_not_contains(on_disk3, "WHATEVER", "no-op redaction emitted spurious replacement")
    assert_contains(on_disk3, "Bearer-abc123-shh", "no-op redaction wiped real bytes")
    println("  PASS")

    // ---- Test 4: request/response metadata fields can be scrubbed. ----
    println("\nTest 4: request headers/body + response headers redaction")
    vcr.clear_redactions()
    rfull = vcr.record_full_response("POST", "/metadata", 201, "text/plain", "ok",
        "Authorization: Bearer req-secret\nX-Trace: trace-secret\n",
        "payload=req-secret\n",
        "Content-Type: text/plain\nSet-Cookie: session=resp-secret\n")
    if rfull != "" { println("  FAIL: record_full — ${rfull}"); exit(1) }

    rherr = vcr.redact(vcr.FIELD_REQUEST_HEADERS, "req-secret", "REQ-REDACTED")
    if rherr != "" { println("  FAIL: redact request headers — ${rherr}"); exit(1) }
    rberr = vcr.redact(vcr.FIELD_REQUEST_BODY, "req-secret", "REQ-REDACTED")
    if rberr != "" { println("  FAIL: redact request body — ${rberr}"); exit(1) }
    sherr = vcr.redact(vcr.FIELD_RESPONSE_HEADERS, "resp-secret", "RESP-REDACTED")
    if sherr != "" { println("  FAIL: redact response headers — ${sherr}"); exit(1) }

    ferr4 = vcr.flush(TAPE_PATH)
    if ferr4 != "" { println("  FAIL: flush metadata — ${ferr4}"); exit(1) }
    on_disk4, derr4 = fs.read(TAPE_PATH)
    if derr4 != "" { println("  FAIL: read metadata tape — ${derr4}"); exit(1) }
    assert_not_contains(on_disk4, "req-secret", "request secret leaked")
    assert_not_contains(on_disk4, "resp-secret", "response header secret leaked")
    assert_contains(on_disk4, "Authorization: Bearer REQ-REDACTED", "request header not redacted")
    assert_contains(on_disk4, "payload=REQ-REDACTED", "request body not redacted")
    assert_contains(on_disk4, "Set-Cookie: session=RESP-REDACTED", "response header not redacted")
    println("  PASS")

    // ---- Test 5: whole header lines can be removed by name. ----
    println("\nTest 5: request/response header removal")
    herr1 = vcr.remove_header(vcr.FIELD_REQUEST_HEADERS, "authorization")
    if herr1 != "" { println("  FAIL: remove request header — ${herr1}"); exit(1) }
    herr2 = vcr.remove_header(vcr.FIELD_RESPONSE_HEADERS, "Set-Cookie")
    if herr2 != "" { println("  FAIL: remove response header — ${herr2}"); exit(1) }
    ferr5 = vcr.flush(TAPE_PATH)
    if ferr5 != "" { println("  FAIL: flush removed headers — ${ferr5}"); exit(1) }
    on_disk5, derr5 = fs.read(TAPE_PATH)
    if derr5 != "" { println("  FAIL: read removed-header tape — ${derr5}"); exit(1) }
    assert_not_contains(on_disk5, "Authorization:", "request header was not removed")
    assert_not_contains(on_disk5, "Set-Cookie:", "response header was not removed")
    assert_contains(on_disk5, "X-Trace: trace-secret", "unrelated request header was removed")

    vcr.clear_header_removals()
    ferr6 = vcr.flush(TAPE_PATH)
    if ferr6 != "" { println("  FAIL: re-flush after clear removals — ${ferr6}"); exit(1) }
    on_disk6, derr6 = fs.read(TAPE_PATH)
    if derr6 != "" { println("  FAIL: re-read after clear removals — ${derr6}"); exit(1) }
    assert_contains(on_disk6, "Authorization: Bearer REQ-REDACTED", "clear_header_removals did not restore request header")
    assert_contains(on_disk6, "Set-Cookie: session=RESP-REDACTED", "clear_header_removals did not restore response header")
    println("  PASS")

    println("\n=== All VCR redaction tests passed ===")
    vcr.clear_redactions()
    vcr.clear_header_removals()
    exit(0)
}

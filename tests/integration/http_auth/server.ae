// std.http.middleware Bearer + session-cookie auth integration test.
//
// Single-server, single-strategy driver. The test runner launches
// this binary twice — once with argv=bearer, once with argv=session
// — so each strategy runs in isolation. Layering both auth
// middlewares on the same server would gate every route on BOTH
// credentials at once, which isn't what either contract claims.
//
//   bearer  -> :18273  /api/whoami
//   session -> :18274  /app/me
//
// Verifier callbacks live in shim.c so they receive the raw
// `const char*` the C middleware passes, without needing
// Aether-side C-string accessors.

import std.http
import std.http.middleware
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

extern aether_test_bearer_verify(token: ptr, ud: ptr) -> int
extern aether_test_session_verify(cookie_value: ptr, ud: ptr) -> int

handle_whoami(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "bearer-ok")
}

handle_me(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "session-ok")
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

run_server(raw: ptr) {
    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }
    sleep(60000)
    exit(0)
}

main() {
    n = aether_args_count()
    if n < 2 {
        println("FAIL: usage: server <bearer|session>")
        exit(1)
    }
    mode = aether_args_get(1)

    if mode == "bearer" {
        raw = http.server_create(18273)
        if raw == 0 {
            println("FAIL: server_create returned null")
            exit(1)
        }
        err = middleware.use_bearer_auth(raw, "api",
                                          aether_test_bearer_verify, 0)
        if err != "" {
            println("FAIL: use_bearer_auth: ${err}")
            exit(1)
        }
        http.server_get(raw, "/api/whoami", handle_whoami, 0)
        println("READY")
        run_server(raw)
        return
    }

    if mode == "session" {
        raw = http.server_create(18274)
        if raw == 0 {
            println("FAIL: server_create returned null")
            exit(1)
        }
        err = middleware.use_session_auth(raw, "SESSIONID", "/login",
                                           aether_test_session_verify, 0)
        if err != "" {
            println("FAIL: use_session_auth: ${err}")
            exit(1)
        }
        http.server_get(raw, "/app/me", handle_me, 0)
        println("READY")
        run_server(raw)
        return
    }

    println("FAIL: unknown mode: ${mode}")
    exit(1)
}

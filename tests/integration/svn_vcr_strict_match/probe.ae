// VCR strict-match permutation tests.
//
// Drives deliberately-mismatched requests through a small synthetic
// tape (tiny.tape, one interaction) and asserts that the dispatcher
// flagged each with the right KIND_* code. Companion to the byte-
// faithful replay test in svn_checkout_via_vcr/ — that test proves
// the happy path works; this test proves the negative-path
// diagnostic surface (vcr.last_kind / vcr.last_index / vcr.last_error)
// reports what tests need to navigate to root cause without parsing
// 599 response bodies.
//
// Four cases:
//   1. Control: send the exact recorded headers → KIND_OK
//   2. Missing recorded header → KIND_HEADER_MISSING
//   3. Wrong value on recorded header → KIND_HEADER_VALUE_DIFF
//   4. Extra header not in recording → KIND_HEADER_UNEXPECTED
//
// The tape is loaded once and the server runs across all cases;
// vcr.reset_cursor() between cases puts the dispatcher back at
// interaction 0 (cleaner than eject+reload).
//
// We don't test wrong-path or wrong-method here. The routing
// layer registers routes only for paths that appear in the tape
// (vcr_register_routes), so a request to an unregistered path
// never reaches vcr_dispatch — it gets a default 404 from the
// server. Path/method mismatch detection is for the case where
// a TAPE has a method/path mismatch between recorded slot N and
// live request N; the existing happy-path test in
// svn_checkout_via_vcr/ exercises the matching side of that
// already (17 different paths/methods, all successfully matched).

import std.http
import std.http.server.vcr
import std.http.client
import std.string

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18142
const TAPE_REL = "tests/integration/svn_vcr_strict_match/tiny.tape"

// Mirror of the kind enum from std.http.server.vcr/module.ae —
// inline because cross-module qualified-const lookup
// (`vcr.KIND_OK`) hits a codegen ordering issue (the C #define
// for vcr_KIND_OK lands after the function body that uses it).
// Same numeric values as the runtime side (aether_vcr.c
// VCR_KIND_* defines), kept in sync manually.
const KIND_OK                  = 0
const KIND_PATH_OR_METHOD_DIFF = 1
const KIND_HEADER_MISSING      = 2
const KIND_HEADER_VALUE_DIFF   = 3
const KIND_HEADER_UNEXPECTED   = 4
const KIND_TAPE_EXHAUSTED      = 5
const KIND_BODY_DIFF           = 6

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

kind_name(k: int) -> string {
    if k == KIND_OK                  { return "OK" }
    if k == KIND_PATH_OR_METHOD_DIFF { return "PATH_OR_METHOD_DIFF" }
    if k == KIND_HEADER_MISSING      { return "HEADER_MISSING" }
    if k == KIND_HEADER_VALUE_DIFF   { return "HEADER_VALUE_DIFF" }
    if k == KIND_HEADER_UNEXPECTED   { return "HEADER_UNEXPECTED" }
    if k == KIND_TAPE_EXHAUSTED      { return "TAPE_EXHAUSTED" }
    if k == KIND_BODY_DIFF           { return "BODY_DIFF" }
    return "UNKNOWN"
}

// Run one permutation. Returns 1 on pass, 0 on fail.
run_case(label: string, method: string, path: string,
         set_extra_header: int, extra_name: string, extra_value: string,
         skip_xtrace: int, wrong_xtrace_value: int,
         expected_kind: int) -> int {
    // Reset cursor + per-dispatch outcome slots so cases are
    // independent. Server keeps running across all cases.
    vcr.reset_cursor()

    url = "http://127.0.0.1:${PORT}${path}"
    req = client.request(method, url)
    if req == null {
        println("  [${label}] FAIL: client.request rejected")
        return 0
    }
    // Always set Accept: text/plain (one of the recorded headers).
    client.set_header(req, "Accept", "text/plain")
    // Conditionally set X-Trace-Id — recorded value is "42".
    if skip_xtrace == 0 {
        if wrong_xtrace_value == 1 {
            client.set_header(req, "X-Trace-Id", "999")
        } else {
            client.set_header(req, "X-Trace-Id", "42")
        }
    }
    // Conditionally set the unexpected extra header.
    if set_extra_header == 1 {
        client.set_header(req, extra_name, extra_value)
    }

    resp, cerr = client.send_request(req)
    client.request_free(req)
    if cerr != "" {
        println("  [${label}] FAIL: transport error: ${cerr}")
        return 0
    }

    got_kind = vcr.last_kind()
    got_index = vcr.last_index()
    got_msg = vcr.last_error()
    got_status = client.response_status(resp)
    client.response_free(resp)

    if got_kind != expected_kind {
        println("  [${label}] FAIL: expected kind=${kind_name(expected_kind)}, got kind=${kind_name(got_kind)} (status ${got_status})")
        if got_msg != "" {
            println("    last_error: ${got_msg}")
        }
        return 0
    }
    if expected_kind == KIND_OK {
        if got_status != 200 {
            println("  [${label}] FAIL: kind OK but status ${got_status}, expected 200")
            return 0
        }
    } else {
        // Mismatch cases must produce a 599.
        if got_status != 599 {
            println("  [${label}] FAIL: kind=${kind_name(got_kind)} but status ${got_status}, expected 599")
            return 0
        }
        // Mismatch cases must populate last_error with diagnostic.
        if got_msg == "" {
            println("  [${label}] FAIL: kind=${kind_name(got_kind)} but last_error is empty")
            return 0
        }
    }
    if got_index != 0 {
        println("  [${label}] FAIL: expected index=0, got index=${got_index}")
        return 0
    }

    println("  [${label}] PASS (kind=${kind_name(got_kind)}, status=${got_status})")
    return 1
}

main() {
    println("VCR strict-match permutation tests")
    println("")

    srv = vcr.load(TAPE_REL, PORT)
    if srv == null {
        println("FAIL: vcr.load returned null")
        exit(1)
    }
    vcr.set_strict_headers(1)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: srv }
    sleep(500)

    passed = 0
    failed = 0

    // Case 1: control — exact recorded request → KIND_OK.
    r1 = run_case("1. control",
        "GET", "/strict",
        0, "", "",
        0, 0,
        KIND_OK)
    if r1 == 1 { passed = passed + 1 } else { failed = failed + 1 }

    // Case 2: skip recorded header → KIND_HEADER_MISSING.
    r2 = run_case("2. missing recorded header",
        "GET", "/strict",
        0, "", "",
        1, 0,
        KIND_HEADER_MISSING)
    if r2 == 1 { passed = passed + 1 } else { failed = failed + 1 }

    // Case 3: wrong header value → KIND_HEADER_VALUE_DIFF.
    r3 = run_case("3. wrong header value",
        "GET", "/strict",
        0, "", "",
        0, 1,
        KIND_HEADER_VALUE_DIFF)
    if r3 == 1 { passed = passed + 1 } else { failed = failed + 1 }

    // Case 4: extra header not in recording → KIND_HEADER_UNEXPECTED.
    r4 = run_case("4. unexpected extra header",
        "GET", "/strict",
        1, "X-Custom", "boom",
        0, 0,
        KIND_HEADER_UNEXPECTED)
    if r4 == 1 { passed = passed + 1 } else { failed = failed + 1 }

    vcr.eject(srv)
    println("")
    println("svn_vcr_strict_match: ${passed} passing, ${failed} failing (of 4)")
    if failed > 0 {
        exit(1)
    }
    exit(0)
}

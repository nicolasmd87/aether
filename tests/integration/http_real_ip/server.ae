// std.http.middleware.use_real_ip integration test driver.
//
// Spins up an HTTP server with the Real-IP middleware enabled.
// The /whoami route reads X-Real-IP from the request headers and
// echoes it back, so the shell runner can verify the middleware
// extracted the leftmost X-Forwarded-For value correctly.

import std.http
import std.http.middleware
import std.os

extern exit(code: int)
// Use raw form: actor receive handlers can't cleanly discard the
// wrapper's string return without an unused-result warning.
extern http_server_start_raw(server: ptr) -> int

const PORT = 18272

handle_whoami(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    real = http.get_header(req, "X-Real-IP")
    if real == null {
        real = ""
    }
    http.response_set_body(res, "ip=${real}")
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    // Empty header_name argument -> default "X-Forwarded-For".
    err = middleware.use_real_ip(raw, "")
    if err != "" {
        println("FAIL: use_real_ip: ${err}")
        exit(1)
    }

    println("READY")

    http.server_get(raw, "/whoami", handle_whoami, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

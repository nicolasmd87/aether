// HTTP/2 per-stream concurrent dispatch — integration test driver.
//
// Spins up an HTTP/2 server with 4 dispatch workers. The /slow
// route sleeps for 500 ms inside the handler, so when the shell
// runner sends N parallel requests on one h2 connection, the total
// elapsed time tells us whether the handlers ran concurrently or
// were serialised on the connection thread:
//
//   - workers = 0 (sequential): N requests * 500 ms ~= N * 500 ms
//   - workers = 4 (concurrent): up to 4 requests in parallel, so
//                               4 streams complete in ~500 ms total
//
// The shell asserts the parallel branch — total under (N/4 + 1) *
// 600 ms — proving the pool actually parallelises handler work.
//
// The /fast route is a sanity check (no sleep) used to confirm the
// server is responsive before the timing-sensitive parallel test.

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18280

handle_slow(req: ptr, res: ptr, ud: ptr) {
    // sleep is implemented in std.os and yields the calling thread;
    // when this handler runs on a worker pool thread, other workers
    // can pick up other streams in parallel.
    sleep(500)
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    q = http.request_query(req)
    if q == null { q = "" }
    http.response_set_body(res, "slow:${q}")
}

handle_fast(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "fast")
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    ka_err = http.server_set_keepalive(raw, 1, 0, 5000)
    if ka_err != "" {
        println("FAIL: server_set_keepalive: ${ka_err}")
        exit(1)
    }

    h2_err = http.server_set_h2(raw, 0)
    if h2_err != "" {
        println("READY-NOH2: ${h2_err}")
    } else {
        // 4 dispatch workers: handlers can run 4-way concurrently
        // per connection. Driver verifies the speedup empirically.
        cd_err = http.server_set_h2_concurrent_dispatch(raw, 4)
        if cd_err != "" {
            println("FAIL: server_set_h2_concurrent_dispatch: ${cd_err}")
            exit(1)
        }
        println("READY")
    }

    http.server_get(raw, "/slow", handle_slow, 0)
    http.server_get(raw, "/fast", handle_fast, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

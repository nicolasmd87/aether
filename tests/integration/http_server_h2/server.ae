// #260 Tier 2: HTTP/2 server end-to-end integration test driver.
//
// Spins up an HTTP server on port 18260 with HTTP/2 enabled. The
// shell runner exercises both:
//   - h2c (HTTP/2 cleartext over plain TCP, RFC 7540 §3.2 Upgrade
//     path AND prior-knowledge flavour)
//   - h2 over TLS (ALPN-negotiated) is a separate test driver
//     because it needs cert+key fixtures.
//
// Skips cleanly when libnghttp2 isn't linked into the build.

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18260

handle_root(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_header(res, "X-Aether-Proto", "h2")
    http.response_set_body(res, "h2-ok")
}

handle_echo(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    body = http.request_body(req)
    if body == null {
        body = ""
    }
    http.response_set_body(res, body)
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    // Enable HTTP/1.1 keep-alive AND HTTP/2 — clients pick whichever
    // they speak. The keep-alive enabling is what makes h2c upgrade
    // viable on the same port (the connection has to survive past
    // the first request).
    ka_err = http.server_set_keepalive(raw, 1, 0, 5000)
    if ka_err != "" {
        println("FAIL: server_set_keepalive: ${ka_err}")
        exit(1)
    }

    h2_err = http.server_set_h2(raw, 0)  // 0 → nghttp2 default 100
    if h2_err != "" {
        // libnghttp2 not linked into this build — the shell runner
        // detects READY-without-H2 and skips cleanly. The HTTP/1.1
        // path stays usable.
        println("READY-NOH2: ${h2_err}")
    } else {
        println("READY")
    }

    http.server_get(raw, "/",     handle_root, 0)
    http.server_post(raw, "/echo", handle_echo, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}

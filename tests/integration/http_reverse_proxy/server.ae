// std.http.proxy reverse-proxy integration test driver.
//
// Runs as one of three roles, selected by argv[1]:
//
//   upstream      — bind :19001, serve /echo + /slow
//   proxy         — bind :19000, simple proxy → http://localhost:19001 (30s timeout)
//   proxy_timeout — bind :19000, simple proxy → http://localhost:19001 (1s timeout)
//
// The shell driver boots two of these processes (upstream + proxy)
// because Aether's actor scheduler can't run two blocking accept
// loops in one process — http_server_start_raw is a blocking
// poll/accept loop that monopolises its scheduler thread.

import std.http
import std.http.proxy
import std.os

// Use raw form: actor receive handlers can't cleanly discard the
// wrapper's string return without an unused-result warning.
extern http_server_start_raw(server: ptr) -> int
extern exit(code: int)

const UPSTREAM_PORT = 19001
const PROXY_PORT    = 19000

// Upstream handlers ---------------------------------------------

handle_upstream_echo(req: ptr, res: ptr, ud: ptr) {
    xff   = http.get_header(req, "X-Forwarded-For")
    xfp   = http.get_header(req, "X-Forwarded-Proto")
    xfh   = http.get_header(req, "X-Forwarded-Host")
    via   = http.get_header(req, "Via")
    host  = http.get_header(req, "Host")
    hopby = http.get_header(req, "X-Hopby-Custom")
    if xff  == null { xff  = "<none>" }
    if xfp  == null { xfp  = "<none>" }
    if xfh  == null { xfh  = "<none>" }
    if via  == null { via  = "<none>" }
    if host == null { host = "<none>" }
    if hopby == null { hopby = "<none>" }

    body = http.request_body(req)
    blen = http.request_body_length(req)
    body_marker = "<empty>"
    if body != null && blen > 0 {
        body_marker = "body=${blen}"
    }

    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_header(res, "X-Upstream-Tag", "U")
    http.response_set_body(res,
        "upstream-ok\nhost=${host}\nxff=${xff}\nxfp=${xfp}\nxfh=${xfh}\nvia=${via}\nhopby=${hopby}\n${body_marker}\n")
}

handle_upstream_echo_post(req: ptr, res: ptr, ud: ptr) {
    body = http.request_body(req)
    blen = http.request_body_length(req)
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "application/octet-stream")
    if body == null {
        http.response_set_body(res, "")
    } else {
        http.response_set_body_n(res, body, blen)
    }
}

handle_upstream_slow(req: ptr, res: ptr, ud: ptr) {
    sleep(3000)  // 3s — exceeds the 1s proxy timeout
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    http.response_set_body(res, "slow-ok\n")
}

// Actors --------------------------------------------------------

message StartSrv { raw: ptr }
message Noop {}
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

run_server(srv: ptr) {
    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: srv }
    sleep(60000)
    exit(0)
}

run_upstream() {
    up = http.server_create(UPSTREAM_PORT)
    if up == 0 {
        println("FAIL: upstream server_create")
        exit(1)
    }
    ka = http.server_set_keepalive(up, 1, 0, 5000)
    if ka != "" { println("FAIL: keepalive: ${ka}"); exit(1) }
    http.server_get(up,  "/echo", handle_upstream_echo,      0)
    http.server_post(up, "/echo", handle_upstream_echo_post, 0)
    http.server_get(up,  "/slow", handle_upstream_slow,      0)
    println("READY")
    run_server(up)
}

run_proxy(timeout_sec: int) {
    p = http.server_create(PROXY_PORT)
    if p == 0 {
        println("FAIL: proxy server_create")
        exit(1)
    }
    ka = http.server_set_keepalive(p, 1, 0, 5000)
    if ka != "" { println("FAIL: keepalive: ${ka}"); exit(1) }
    err = proxy.use_simple_proxy(p, "/", "http://localhost:19001", timeout_sec)
    if err != "" { println("FAIL: use_simple_proxy: ${err}"); exit(1) }
    println("READY")
    run_server(p)
}

main() {
    n = aether_args_count()
    if n < 2 {
        println("FAIL: usage: server <upstream|proxy|proxy_timeout>")
        exit(1)
    }
    role = aether_args_get(1)

    if role == "upstream" {
        run_upstream()
        return
    }
    if role == "proxy" {
        run_proxy(30)
        return
    }
    if role == "proxy_timeout" {
        run_proxy(1)
        return
    }
    println("FAIL: unknown role: ${role}")
    exit(1)
}

// Parent-side probe for aeocha's structured aeb-report path.
//
// Spawns a compiled child binary via os.run_pipe_drain_and_wait —
// the same surface aeb's driver_test uses — and asserts that the
// payload received on the parent channel is the v1 structured
// report defined in docs/aeocha-aeb-ipc-reporting.md.
//
// Asserts:
//   - Header KV block: version=1, total=3, passed=1, failed=2,
//     errored=0, duration_ms present.
//   - "\n---\n" separator between header and rows.
//   - Three tab-packed rows in order: PASS alpha, FAIL beta with
//     "expected 1 got 2" message, FAIL gamma with "needle missing".
//   - Child exit code == 1 (two failing it() cases).
//
// On any mismatch the probe prints FAIL and exits 1; the shell
// wrapper greps for the "OK" tail line.

import std.os
import std.fs
import std.string
import std.list

extern exit(code: int)

const CHILD_SRC = "tests/integration/aeocha_aeb_ipc_reporting/child.ae"
const CHILD_BIN = "/tmp/aeocha_aeb_ipc_reporting_child"

build_child() -> string {
    argv = list.new()
    list.add(argv, "build")
    list.add(argv, CHILD_SRC)
    list.add(argv, "-o")
    list.add(argv, CHILD_BIN)
    out, exit_code, err = os.run_capture("build/ae", argv, null)
    if err != "" { return "spawn error: ${err}" }
    if exit_code != 0 {
        return "ae build exit ${exit_code}: ${out}"
    }
    return ""
}

fail(msg: string) {
    println("FAIL: ${msg}")
    fs.delete(CHILD_BIN)
    exit(1)
}

assert_eq_str(actual: string, expected: string, label: string) {
    if string_equals(actual, expected) == 0 {
        fail("${label}: expected '${expected}', got '${actual}'")
    }
}

main() {
    println("aeocha aeb-ipc-reporting test")

    berr = build_child()
    if berr != "" {
        println("FAIL: cannot build child: ${berr}")
        exit(1)
    }
    println("  ✓ child compiled to ${CHILD_BIN}")

    argv = list.new()
    report, exit_code, err = os.run_pipe_drain_and_wait(CHILD_BIN, argv, null)

    if err != "" { fail("spawn error: ${err}") }
    if exit_code != 1 {
        fail("expected child exit=1 (two FAIL it()s), got ${exit_code}; report:\n${report}")
    }
    if string_length(report) == 0 {
        fail("empty report — child did not emit through parent channel")
    }

    // Split header from rows on "\n---\n".
    sep_idx = string_index_of(report, "\n---\n")
    if sep_idx < 0 {
        fail("missing '---' separator in report:\n${report}")
    }
    header = string_substring(report, 0, sep_idx)
    rows_blob = string_substring(report, sep_idx + 5, string_length(report))

    // Parse header KV lines.
    header_lines = string_split(header, "\n")
    n_header = string_array_size(header_lines)

    version = ""
    total_str = ""
    passed_str = ""
    failed_str = ""
    errored_str = ""
    duration_str = ""

    i = 0
    while i < n_header {
        line = string_array_get(header_lines, i)
        if string_starts_with(line, "version=") == 1 {
            version = string_substring(line, 8, string_length(line))
        }
        if string_starts_with(line, "total=") == 1 {
            total_str = string_substring(line, 6, string_length(line))
        }
        if string_starts_with(line, "passed=") == 1 {
            passed_str = string_substring(line, 7, string_length(line))
        }
        if string_starts_with(line, "failed=") == 1 {
            failed_str = string_substring(line, 7, string_length(line))
        }
        if string_starts_with(line, "errored=") == 1 {
            errored_str = string_substring(line, 8, string_length(line))
        }
        if string_starts_with(line, "duration_ms=") == 1 {
            duration_str = string_substring(line, 12, string_length(line))
        }
        i = i + 1
    }
    string_array_free(header_lines)

    assert_eq_str(version,     "1", "header version")
    assert_eq_str(total_str,   "3", "header total")
    assert_eq_str(passed_str,  "1", "header passed")
    assert_eq_str(failed_str,  "2", "header failed")
    assert_eq_str(errored_str, "0", "header errored")
    if string_length(duration_str) == 0 {
        fail("missing duration_ms in header")
    }

    println("  ✓ header KV (version=1, total=3, passed=1, failed=2, errored=0, duration_ms=${duration_str})")

    // Per-it rows: STATUS\tindex\t"name"\tduration_ms[\tfailure_message]
    rows = string_split(rows_blob, "\n")
    n_rows = string_array_size(rows)

    real_rows = 0
    j = 0
    while j < n_rows {
        line = string_array_get(rows, j)
        if string_length(line) > 0 {
            real_rows = real_rows + 1
        }
        j = j + 1
    }
    if real_rows != 3 {
        fail("expected 3 it() rows, got ${real_rows}; rows blob:\n${rows_blob}")
    }

    row0 = string_array_get(rows, 0)
    if string_starts_with(row0, "PASS\t1\t\"alpha\"") == 0 {
        fail("row 0 should start 'PASS\\t1\\t\"alpha\"', got: ${row0}")
    }

    row1 = string_array_get(rows, 1)
    if string_starts_with(row1, "FAIL\t2\t\"beta\"") == 0 {
        fail("row 1 should start 'FAIL\\t2\\t\"beta\"', got: ${row1}")
    }
    if string_contains(row1, "expected 1 got 2") == 0 {
        fail("row 1 should contain 'expected 1 got 2', got: ${row1}")
    }

    row2 = string_array_get(rows, 2)
    if string_starts_with(row2, "FAIL\t3\t\"gamma\"") == 0 {
        fail("row 2 should start 'FAIL\\t3\\t\"gamma\"', got: ${row2}")
    }
    if string_contains(row2, "needle missing") == 0 {
        fail("row 2 should contain 'needle missing', got: ${row2}")
    }

    string_array_free(rows)

    println("  ✓ three it() rows in order with correct status/name/message")
    fs.delete(CHILD_BIN)
    println("OK")
    exit(0)
}

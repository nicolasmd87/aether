// Child process for the aeocha-aeb-ipc-reporting integration test.
//
// Runs three aeocha it() cases — one passing, two failing —
// then run_summary(). When the parent (probe.ae) spawned this
// via os.run_pipe_drain_and_wait, std.ipc.parent_channel()
// returns a non-negative fd and run_summary writes the v1
// structured report through it.
//
// We assert specific shapes so the parent's parser can pin
// expectations:
//   - First it: PASS, name "alpha"
//   - Second it: FAIL with message containing "expected 1 got 2"
//   - Third it: FAIL with message containing "needle missing"
// Test exit code is 1 (because two fails); the parent treats
// that as the expected outcome.

import contrib.aeocha

main() {
    fw = aeocha.init()

    aeocha.describe(fw, "ipc reporting cases") {
        aeocha.it("alpha") callback {
            aeocha.assert_eq(fw, 1, 1, "trivially equal")
        }
        aeocha.it("beta") callback {
            aeocha.assert_eq(fw, 1, 2, "should fail: expected 1 got 2")
        }
        aeocha.it("gamma") callback {
            aeocha.assert_contains(fw, "haystack", "needle missing", "should fail: needle missing")
        }
    }

    aeocha.run_summary(fw)
}

// Test: defer trailing block — "configure then execute" pattern
// The block runs first (filling config), then the function executes with it.

import std.map

// --- Builder functions: these use _ctx to set config entries ---

set_release(_ctx: ptr, version: string) {
    map_put(_ctx, "release", version)
}

set_lint(_ctx: ptr, level: string) {
    map_put(_ctx, "lint", level)
}

set_werror(_ctx: ptr) {
    map_put(_ctx, "werror", "true")
}

// --- Defer function: block configures, then this executes ---

defer compile(src: string) {
    // _defer is the config map filled by the trailing block
    rel = ""
    lint_level = ""
    werror = 0

    if _defer != null {
        if map_has(_defer, "release") == 1 {
            rel = map_get(_defer, "release")
        }
        if map_has(_defer, "lint") == 1 {
            lint_level = map_get(_defer, "lint")
        }
        if map_has(_defer, "werror") == 1 {
            werror = 1
        }
    }

    println("compile: ${src} release=${rel} lint=${lint_level} werror=${werror}")
}

// --- Another defer function without trailing block (zero-config) ---

defer build_jar(name: string) {
    has_cfg = 0
    if _defer != null {
        has_cfg = 1
    }
    println("build_jar: ${name} has_config=${has_cfg}")
}

main() {
    // Defer call WITH trailing block — block fills config first
    compile("Main.java") {
        set_release("21")
        set_lint("all")
        set_werror()
    }

    // Defer call WITHOUT trailing block — zero-config
    compile("Test.java")

    // Another defer function with config
    build_jar("app") {
        set_release("17")
    }

    println("defer ok")
}

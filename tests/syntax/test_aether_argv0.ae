// Test: aether_argv0 / os.argv0()
//
// Verifies the two ways to read argv[0]:
//   1. `aether_argv0()` — raw extern, returns null on uninitialised state
//   2. `os.argv0()`     — wrapper, returns "" on uninitialised state
//
// Both should agree with `aether_args_get(0)` when the runtime has been
// initialised via `main`, which is always true for a compiled .ae program.

import std.os
import std.string

extern string_length(s: string) -> int
extern println(s: string)
extern exit(code: int)

main() {
    println("start argv0 test")
    // Raw extern: should never be null in a compiled program because
    // main's runtime init always runs before user code.
    raw = aether_argv0()
    println("got raw")
    if raw == null {
        println("FAIL: aether_argv0() returned null inside main")
        exit(1)
    }

    // Wrapper: returns "" on null, otherwise a fresh copy.
    wrapped = os.argv0()
    if string_length(wrapped) == 0 {
        println("FAIL: os.argv0() returned empty inside main")
        exit(1)
    }

    // Must agree byte-for-byte with aether_args_get(0).
    via_get = aether_args_get(0)
    if via_get == null {
        println("FAIL: aether_args_get(0) returned null")
        exit(1)
    }
    if raw != via_get {
        println("FAIL: aether_argv0 != aether_args_get(0)")
        exit(1)
    }

    // The wrapped copy must have the same length as the raw string —
    // cheap proxy for "same contents" that avoids depending on
    // string comparison operators.
    if string_length(wrapped) != string_length(raw) {
        println("FAIL: os.argv0() length mismatch")
        exit(1)
    }

    println("aether_argv0 ok")
}

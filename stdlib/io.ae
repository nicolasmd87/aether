// Aether Standard Library - I/O Module
// This module provides basic input/output functionality

// Print functions
func print_string(str: string) {
    print("%s", str);
}

func print_int(value: int) {
    print("%d", value);
}

func print_float(value: float) {
    print("%f", value);
}

func print_bool(value: bool) {
    if (value) {
        print("true");
    } else {
        print("false");
    }
}

func print_line(str: string) {
    print("%s\n", str);
}


// Example: Minimal Aether Syntax (Python-style, types inferred!)

struct Point {
    x,  // Type inferred from initialization
    y
}

// Function - types inferred from usage!
distance(p1, p2) {
    dx = p2.x - p1.x;
    dy = p2.y - p1.y;
    return dx * dx + dy * dy;
}

main() {
    p1 = Point{ x: 0, y: 0 };
    p2 = Point{ x: 3, y: 4 };
    
    d = distance(p1, p2);
    print(d);  // 25
    
    print(p1.x);
    print(p1.y);
}


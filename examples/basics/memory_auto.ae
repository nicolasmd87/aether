// Memory Auto Mode (opt-in)
//
// Auto-free mode is opt-in. Enable it in aether.toml:
//   [memory]
//   mode = "auto"
//
// Or for a single run:
//   ae run --auto-free examples/basics/memory_auto.ae
//
// In auto mode, the compiler injects free calls at scope exit
// for stdlib allocations whose constructors have a matching _free.
//
// Run: ae run --auto-free examples/basics/memory_auto.ae

import std.list

main() {
    items = list_new();
    list_add(items, "Aether");
    list_add(items, "is");
    list_add(items, "fast");

    n = list_size(items);
    print("Item count: ");
    print(n);
    print("\n");

    nums = list_new();
    list_add(nums, "one");
    list_add(nums, "two");
    list_add(nums, "three");

    m = list_size(nums);
    print("Number count: ");
    print(m);
    print("\n");

    // In auto mode: list_free(items) and list_free(nums) injected at scope exit.
    // In default (manual) mode: use defer instead (see memory_defer.ae).
}

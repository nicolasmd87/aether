// Import aliasing demonstration
// Shows how to import modules with shorter aliases
//
// Syntax:
//   import std.math           -- import std.math, use as 'math'
//   import std.string as str  -- import std.string, refer to it as 'str'
//
// Then use: math.sqrt(16), str.new("hello")

import std.string

main() {
    // Using imported string functions
    print("=== Import Example ===\n");
    print("Imported std.string module\n");
    print("String functions are now available!\n");
}

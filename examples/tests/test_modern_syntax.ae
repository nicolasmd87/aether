// Modern Aether syntax demonstration

main() {
    // Array literals with type inference
    values = [1, 2, 3, 4, 5];
    
    // Array indexing
    x = values[0];
    y = values[1];
    
    // Math operations
    sum = x + y;
    
    print(x);
    print(y);
    print(sum);
}


# Build artifacts
/build/
/bin/
/out/

# Compiled object files, executables, and generated binaries
*.o
*.exe
aether_program
aetherc

# Generated C files from the Aether compiler (if not tracked)
build/*.c


# Temporary files and logs
*.tmp
*.log
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Editor/IDE directories and files
# Note: Language support files are in editor/vscode/ and are tracked
# User-specific workspace settings are ignored below
.vscode/
.idea/

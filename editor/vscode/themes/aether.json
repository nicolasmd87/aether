{
  "name": "Aether",
  "type": "dark",
  "comments": [
    "Erlang-flavoured palette. The classic Emacs erlang-mode look:",
    "  - Comments: firebrick-red italic (Erlang's signature)",
    "  - Strings:  salmon",
    "  - Keywords: purple (case, of, end, fun, receive, after, …)",
    "  - Atoms / message names: forest green (the dispatch tags",
    "    flowing through the message bus — atoms in Erlang)",
    "  - Variables: gold / tan (font-lock-variable-name-face)",
    "  - Types:    green (font-lock-type-face)",
    "  - Functions: blue, bold for definitions",
    "  - Numbers:  orange",
    "Pattern arrows `->`, the cons-cell pipe `|`, and the actor",
    "send/ask operators (`!`, `?`) keep a coral hue for visual",
    "weight at the dispatch site."
  ],
  "colors": {
    "editor.background":              "#1a1a1a",
    "editor.foreground":              "#d4d4d4",
    "editorLineNumber.foreground":    "#5a5a5a",
    "editorLineNumber.activeForeground": "#bdbdbd",
    "editorCursor.foreground":        "#fa8072",
    "editor.selectionBackground":     "#3a3a3a",
    "editor.lineHighlightBackground": "#222222",
    "editor.selectionHighlightBackground": "#2c2c2c",
    "editorBracketMatch.background":  "#3a3a3a",
    "editorBracketMatch.border":      "#bf6fff",
    "editorIndentGuide.background":   "#2c2c2c",
    "editorIndentGuide.activeBackground": "#3a3a3a",
    "editorWhitespace.foreground":    "#3b3b3b",
    "editorGutter.background":        "#1a1a1a",
    "editorWidget.background":        "#222222",
    "editorHoverWidget.background":   "#222222",
    "editorHoverWidget.border":       "#3a3a3a",
    "editorSuggestWidget.background": "#222222",
    "editorSuggestWidget.border":     "#1a1a1a",
    "editorSuggestWidget.selectedBackground": "#2c2c2c",
    "editorError.foreground":         "#cc6666",
    "editorWarning.foreground":       "#ff9966",
    "editorInfo.foreground":          "#5fa8d3"
  },
  "tokenColors": [
    {
      "name": "Comments — Erlang firebrick red italic",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#cc6666",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings — salmon",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double.aether"
      ],
      "settings": {
        "foreground": "#fa8072"
      }
    },
    {
      "name": "Escape sequences inside strings",
      "scope": [
        "constant.character.escape",
        "constant.character.escape.aether"
      ],
      "settings": {
        "foreground": "#ff9966"
      }
    },
    {
      "name": "String interpolation delimiters",
      "scope": [
        "punctuation.section.interpolation",
        "punctuation.section.interpolation.begin.aether",
        "punctuation.section.interpolation.end.aether",
        "meta.interpolation.aether"
      ],
      "settings": {
        "foreground": "#bf6fff"
      }
    },
    {
      "name": "Numbers — orange",
      "scope": [
        "constant.numeric",
        "constant.numeric.aether"
      ],
      "settings": {
        "foreground": "#ff9966"
      }
    },
    {
      "name": "Boolean / null / self literals",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.aether"
      ],
      "settings": {
        "foreground": "#88ee88",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Control flow keywords (match, receive, if, return, spawn, ...) — Erlang purple",
      "scope": [
        "keyword.control",
        "keyword.control.aether",
        "keyword.control.flow",
        "keyword.control.flow.aether"
      ],
      "settings": {
        "foreground": "#bf6fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage and declaration keywords (actor, struct, message, state, ...) — Erlang purple",
      "scope": [
        "storage.type",
        "storage.type.aether",
        "storage.modifier",
        "storage.modifier.aether",
        "keyword.declaration.aether",
        "keyword.other.aether"
      ],
      "settings": {
        "foreground": "#bf6fff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Built-in primitive types (int, string, bool, ...) — forest green",
      "scope": [
        "support.type.primitive.aether",
        "support.type.builtin.aether"
      ],
      "settings": {
        "foreground": "#88ee88"
      }
    },
    {
      "name": "Message names — atoms (Erlang dispatch tags), forest green bold",
      "scope": [
        "entity.name.message.aether",
        "entity.name.type.message"
      ],
      "settings": {
        "foreground": "#88ee88",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Actor names — forest green bold (akin to module names in Erlang)",
      "scope": [
        "entity.name.actor.aether",
        "entity.name.type.actor"
      ],
      "settings": {
        "foreground": "#88ee88",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Struct names and other user-defined types — forest green",
      "scope": [
        "entity.name.type",
        "entity.name.type.aether",
        "entity.name.struct",
        "entity.name.struct.aether",
        "support.type"
      ],
      "settings": {
        "foreground": "#88ee88"
      }
    },
    {
      "name": "Function definitions — blue bold",
      "scope": [
        "entity.name.function",
        "entity.name.function.aether"
      ],
      "settings": {
        "foreground": "#5fa8d3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "main() entry point — blue bold italic",
      "scope": [
        "entity.name.function.main",
        "entity.name.function.main.aether",
        "support.function.main"
      ],
      "settings": {
        "foreground": "#5fa8d3",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Function call sites (bare and namespaced) — blue",
      "scope": [
        "meta.function-call",
        "support.function",
        "support.function.aether"
      ],
      "settings": {
        "foreground": "#5fa8d3"
      }
    },
    {
      "name": "Variables and parameters — gold (Erlang variable face)",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.aether",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#dcdcaa"
      }
    },
    {
      "name": "Pattern arrow `->` — the dispatch glyph for receive arms and function returns",
      "scope": [
        "keyword.operator.arrow.aether",
        "keyword.operator.pattern.aether",
        "punctuation.separator.arrow"
      ],
      "settings": {
        "foreground": "#fa8072",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Cons-cell pattern `[h | t]` — pipe is a join, not an or",
      "scope": [
        "meta.pattern.cons.aether",
        "punctuation.separator.cons.aether"
      ],
      "settings": {
        "foreground": "#fa8072",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Actor send `!` and ask `?` operators — Erlang's literal send glyph",
      "scope": [
        "keyword.operator.actor.aether"
      ],
      "settings": {
        "foreground": "#bf6fff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Assignment, comparison, logical, arithmetic, bitwise operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.aether",
        "keyword.operator.assignment.aether",
        "keyword.operator.comparison.aether",
        "keyword.operator.logical.aether",
        "keyword.operator.arithmetic.aether",
        "keyword.operator.bitwise.aether",
        "keyword.operator.type.pointer.aether"
      ],
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Punctuation (braces, brackets, parens, semicolons, commas) — soft gray",
      "scope": [
        "punctuation.section",
        "punctuation.definition",
        "punctuation.terminator",
        "punctuation.separator",
        "punctuation.accessor.aether"
      ],
      "settings": {
        "foreground": "#a0a0a0"
      }
    }
  ]
}

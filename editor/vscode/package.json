{
  "name": "aether-language",
  "displayName": "Aether Language Support",
  "description": "Language support for Aether with LSP",
  "version": "0.1.0",
  "publisher": "aether",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:aether"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aether",
        "aliases": [
          "Aether",
          "aether"
        ],
        "extensions": [
          ".ae"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aether",
        "scopeName": "source.aether",
        "path": "./aether.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Aether",
      "properties": {
        "aether.lsp.path": {
          "type": "string",
          "default": "aether-lsp",
          "description": "Path to Aether LSP server executable"
        },
        "aether.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^4.9.0"
  }
}

